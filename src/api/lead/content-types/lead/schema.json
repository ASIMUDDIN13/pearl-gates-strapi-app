{
  "kind": "collectionType",
  "collectionName": "leads",
  "info": {
    "singularName": "lead",
    "pluralName": "leads",
    "displayName": "Lead",
    "description": "Leads captured from landing pages and contact forms"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email"
    },
    "phone": {
      "type": "string"
    },
    "message": {
      "type": "text"
    },
    "source_page": {
      "type": "string"
    },
    "listing_location": {
      "type": "string"
    },
    "preferred_date": {
      "type": "date"
    },
    "preferred_time": {
      "type": "string"
    },
    "budget_qar": {
      "type": "integer"
    },
    "lead_tier": {
      "type": "enumeration",
      "enum": ["tier1", "tier2", "tier3"],
      "default": "tier1"
    },
    "lead_type": {
      "type": "enumeration",
      "enum": ["buyer", "renter", "investor", "general"],
      "default": "general"
    },
    "lead_status": {
      "type": "enumeration",
      "enum": ["new", "contacted", "qualified", "closed", "lost"],
      "default": "new"
    },
    "consent_accepted": {
      "type": "boolean",
      "default": false
    },
    "utm_source": {
      "type": "string"
    },
    "utm_medium": {
      "type": "string"
    },
    "utm_campaign": {
      "type": "string"
    },
    "gclid": {
      "type": "string"
    },
    "landing_page_url": {
      "type": "string"
    },
    "property_interest": {
      "type": "string"
    },
    "form_data": {
      "type": "json"
    }
  }
}
